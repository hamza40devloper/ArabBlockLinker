# استخدام نسخة جافا 17 المستقرة والخفيفة المعتمدة على Alpine Linux
FROM eclipse-temurin:17-jre-alpine

# تثبيت حزم bash و curl اللازمتين لتشغيل السكربت وتحميل ملف الجار
RUN apk add --no-cache bash curl

# تحديد مجلد العمل داخل الحاوية
WORKDIR /minecraft

# نسخ جميع الملفات المرفوعة من جيت هاب إلى داخل الحاوية
COPY . .

# إعطاء صلاحيات التشغيل الكاملة لسكربت البداية
RUN chmod +x start.sh

# فتح منفذ الماين كرافت الافتراضي للاعبين
EXPOSE 25565

# أمر بدء الحاوية وتشغيل السيرفر
CMD ["./start.sh"]
